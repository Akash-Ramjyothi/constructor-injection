# Auto-detect text files and ensure consistent line endings
* text=auto

# Explicitly enforce LF for all text files
*.sh text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.jsx text eol=lf
*.tsx text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.xml text eol=lf
*.html text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.gradle text eol=lf
*.properties text eol=lf
*.env text eol=lf
*.gitignore text eol=lf
*.gitattributes text eol=lf

# Maven wrapper scripts
/mvnw text eol=lf
/mvnw.cmd text eol=crlf

# Batch files (Windows)
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files - treat as binary to prevent corruption
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.pdf binary
*.jar binary
*.war binary
*.ear binary
*.zip binary
*.tar.gz binary
*.tgz binary
*.mp4 binary
*.mp3 binary

# Database files
*.db binary
*.sqlite binary

# Executable files
*.exe binary
*.dll binary
*.so binary
*.dylib binary
